// ---- Solution Jenkinsfile for the DevOps Workshop sample app ----
// Place this file at the ROOT of your sample-app repository
// (i.e. sample-app/Jenkinsfile), not inside solution/.

pipeline {
    agent any

    environment {
        IMAGE_NAME = "devops-workshop-app"
        IMAGE_TAG  = "build-${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('sample-app'){
                    sh 'npm install'
                }
            }     
        }

        stage('Test') {
           steps {
                dir('sample-app'){
                    sh 'npm test'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t devops-workshop-app:latest sample-app/"
            }
        }

stage('Smoke Test the Image') {
    steps {
        // 1. Run standard container on default bridge network (no host networking needed)
        sh "docker run -d --name smoke-${BUILD_NUMBER} devops-workshop-app:latest"
        
        // 2. Give the app a few seconds to boot up safely
        sh "sleep 5"
        
        // 3. Dynamically extract the internal container IP address and curl it on port 3000
        sh '''
            CONTAINER_IP=$(docker inspect -f '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}' smoke-${BUILD_NUMBER})
            echo "Targeting Container IP: ${CONTAINER_IP}"
            curl -f http://${CONTAINER_IP}:3000/health
        '''
    }
}

        stage('Push Image') {
            when {
                branch 'main'
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKERHUB_USER',
                    passwordVariable: 'DOCKERHUB_PASS'
                )]) {
                    sh """
                        echo "\$DOCKERHUB_PASS" | docker login -u "\$DOCKERHUB_USER" --password-stdin
                        docker tag ${IMAGE_NAME}:${IMAGE_TAG} \$DOCKERHUB_USER/${IMAGE_NAME}:${IMAGE_TAG}
                        docker push \$DOCKERHUB_USER/${IMAGE_NAME}:${IMAGE_TAG}
                    """
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline succeeded: ${IMAGE_NAME}:${IMAGE_TAG}"
        }
        failure {
            echo "Pipeline failed — check the stage logs above."
        }
        always {
            sh "docker rm -f smoke-${BUILD_NUMBER} || true"
        }
    }
}
